generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PerfilUsuario {
  ADMIN
  OPERACIONAL
}

enum StatusAcessoEmpresa {
  DISPONIVEL
  INDISPONIVEL
  BLOQUEADO
  NAO_VERIFICADO
}

enum StatusProcuracaoEmpresa {
  VALIDA
  INVALIDA
  PENDENTE
  NAO_VERIFICADA
}

enum TipoIntegracao {
  MANUAL
  API
  RPA
}

enum StatusIntegracao {
  ATIVA
  INATIVA
  ERRO
  NAO_CONFIGURADA
}

enum TipoVarredura {
  MANUAL
}

enum StatusExecucaoVarredura {
  INICIADA
  CONCLUIDA
  FALHA
}

enum StatusPendenciaOperacional {
  ABERTA
  RESOLVIDA
}

enum CriticidadePendenciaOperacional {
  BAIXA
  MEDIA
  ALTA
}

enum TipoEventoOperacional {
  VARREDURA_RELEVANTE
  MUDANCA_ESTADO
}

enum TipoPendenciaOperacional {
  ACESSO
  OPERACIONAL
  PROCURACAO
}

enum TipoPendencia {
  ACESSO
  OPERACIONAL
  PROCURACAO
}

enum StatusPendencia {
  ABERTA
  RESOLVIDA
}

enum PrioridadePendencia {
  BAIXA
  MEDIA
  ALTA
}

enum TipoLogExecucao {
  CONFERENCIA_OPERACIONAL
  REGISTRO_PENDENCIA
  REGULARIZACAO_PENDENCIA
  RETIRADA_CARTEIRA
}

enum ResultadoLogExecucao {
  SUCESSO
  SEM_ALTERACAO
  FALHA
}

enum RegimeTributario {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
  OUTRO
}

model UsuarioInterno {
  id           String               @id @default(cuid())
  nome         String
  email        String               @unique
  senhaHash    String
  perfil       PerfilUsuario
  ativo        Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  responsaveis  ResponsavelInterno[]
  pendenciasCriadas Pendencia[] @relation("PendenciaCriadaPor")
  pendenciasAtualizadas Pendencia[] @relation("PendenciaAtualizadaPor")
  logsExecucao  LogExecucao[]
}

model ResponsavelInterno {
  id               String          @id @default(cuid())
  nome             String
  email            String          @unique
  usuarioInternoId String
  usuarioInterno   UsuarioInterno  @relation(fields: [usuarioInternoId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  ativo           Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  empresas        Empresa[]
  pendencias      Pendencia[]

  @@index([usuarioInternoId])
}

model Empresa {
  id                      String               @id @default(cuid())
  cnpj                    String               @unique
  razaoSocial             String
  nomeFantasia            String?
  regimeTributario        RegimeTributario
  responsavelInternoId    String?
  responsavelInterno      ResponsavelInterno?   @relation(fields: [responsavelInternoId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  naCarteira              Boolean              @default(false)
  pendenciaOperacional    Boolean              @default(false)
  statusAcesso            StatusAcessoEmpresa   @default(NAO_VERIFICADO)
  statusProcuracao        StatusProcuracaoEmpresa @default(NAO_VERIFICADA)
  observacoesOperacionais String?               @db.Text
  ultimaConferenciaAcessoEm DateTime?
  ultimaConferenciaOperacionalEm DateTime?
  ultimaConferenciaProcuracaoEm DateTime?
  regularizadaEm          DateTime?
  ultimaVarreduraEm       DateTime?
  ultimoEventoRelevanteEm DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  integracoes             IntegracaoEmpresa[]
  pendenciasOperacionais  PendenciaOperacional[]
  pendencias              Pendencia[]
  logsExecucao            LogExecucao[]
  varreduras              Varredura[]
  eventosOperacionais     EventoOperacional[]

  @@index([responsavelInternoId])
  @@index([naCarteira])
  @@index([pendenciaOperacional])
}

model IntegracaoEmpresa {
  id                String          @id @default(cuid())
  empresaId         String
  empresa           Empresa         @relation(fields: [empresaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tipoIntegracao    TipoIntegracao
  statusIntegracao  StatusIntegracao
  ultimoSucessoEm   DateTime?
  ultimoErroEm      DateTime?
  mensagemErroAtual String?         @db.Text
  observacoes       String?         @db.Text
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([empresaId])
}

model Varredura {
  id             String                   @id @default(cuid())
  empresaId      String
  empresa       Empresa                  @relation(fields: [empresaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tipoVarredura  TipoVarredura
  statusExecucao StatusExecucaoVarredura
  iniciadoEm     DateTime
  finalizadoEm   DateTime?
  resumoResultado String?                 @db.Text
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  eventoOperacional EventoOperacional?

  @@index([empresaId])
  @@index([tipoVarredura])
  @@index([statusExecucao])
}

model EventoOperacional {
  id          String                   @id @default(cuid())
  empresaId   String
  empresa     Empresa                  @relation(fields: [empresaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  varreduraId String                   @unique
  varredura   Varredura                @relation(fields: [varreduraId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tipoEvento  TipoEventoOperacional
  descricao   String                   @db.Text
  metadata    Json?
  createdAt   DateTime                 @default(now())

  @@index([empresaId])
  @@index([varreduraId])
  @@index([tipoEvento])
}

model PendenciaOperacional {
  id         String                    @id @default(cuid())
  empresaId  String
  empresa    Empresa                   @relation(fields: [empresaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tipo       TipoPendenciaOperacional
  status     StatusPendenciaOperacional @default(ABERTA)
  criticidade CriticidadePendenciaOperacional @default(MEDIA)
  descricao  String                    @db.Text
  origem     String?
  resolvedAt DateTime?
  createdAt  DateTime                  @default(now())

  @@index([empresaId])
  @@index([status])
  @@index([empresaId, status, criticidade])
  @@index([tipo])
  @@index([createdAt])
}

model Pendencia {
  id                         String                 @id @default(cuid())
  empresaId                  String
  empresa                    Empresa                @relation(fields: [empresaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  responsavelInternoId       String?
  responsavelInterno         ResponsavelInterno?    @relation(fields: [responsavelInternoId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  tipo                       TipoPendencia
  status                     StatusPendencia        @default(ABERTA)
  prioridade                 PrioridadePendencia    @default(MEDIA)
  titulo                     String
  descricao                  String                 @db.Text
  origem                     String?
  abertaEm                   DateTime               @default(now())
  fechadaEm                  DateTime?
  criadaPorUsuarioInternoId   String?
  criadaPorUsuarioInterno     UsuarioInterno?       @relation("PendenciaCriadaPor", fields: [criadaPorUsuarioInternoId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  atualizadaPorUsuarioInternoId String?
  atualizadaPorUsuarioInterno UsuarioInterno?       @relation("PendenciaAtualizadaPor", fields: [atualizadaPorUsuarioInternoId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
  logsExecucao               LogExecucao[]

  @@index([empresaId])
  @@index([status])
  @@index([prioridade])
  @@index([responsavelInternoId])
  @@index([tipo])
  @@index([abertaEm])
}

model LogExecucao {
  id                        String               @id @default(cuid())
  empresaId                 String
  empresa                   Empresa              @relation(fields: [empresaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  pendenciaId               String?
  pendencia                 Pendencia?           @relation(fields: [pendenciaId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  tipo                      TipoLogExecucao
  resultado                 ResultadoLogExecucao
  resumo                    String
  detalhes                  String?              @db.Text
  executadoPorUsuarioInternoId String?
  executadoPorUsuarioInterno UsuarioInterno?      @relation(fields: [executadoPorUsuarioInternoId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  executadoEm               DateTime             @default(now())
  chaveIdempotencia         String?
  createdAt                 DateTime             @default(now())

  @@index([empresaId])
  @@index([pendenciaId])
  @@index([executadoEm])
  @@index([tipo])
  @@index([resultado])
  @@index([executadoPorUsuarioInternoId])
  @@index([chaveIdempotencia])
}
